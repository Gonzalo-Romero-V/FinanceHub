# ─── Server-side rewrites (next.config.ts) ────────────────────────────────────
# URL interna del backend Laravel — usada por Next.js para los rewrites.
# No lleva prefijo NEXT_PUBLIC_ porque jamás se expone al browser.
BACKEND_URL=http://localhost:8000

# URL interna del servicio LLM (FastAPI).
LLM_URL=http://localhost:8001

# ─── Client-side (baked into browser bundle) ──────────────────────────────────
# Rutas relativas: el browser llama /api/* y Next.js lo proxea al backend.
# No cambiar a URL absoluta o se crea un loop con el tunnel de Cloudflare.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_LLM_API_BASE_URL=/llm-api
