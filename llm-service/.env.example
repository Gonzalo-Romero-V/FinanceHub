# ─── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.0

# ─── Database (misma instancia que Laravel) ───────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=financehub
DB_USER=postgres
DB_PASSWORD=
STATEMENT_TIMEOUT_MS=5000
MAX_ROWS_PER_QUERY=500

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=FinanceHub-LLM-Service
DEBUG=true
PORT=8001
# CORS — CSV de orígenes permitidos. En producción, restringir al dominio real.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000
